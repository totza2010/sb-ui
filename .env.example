# Saltbox UI config — copy to .env, or let the in-app setup wizard write it.
# Connection to the Saltbox host (leave HOST empty to run in local mode).
SALTBOX_CONFIGURED=false
SALTBOX_HOST=
SALTBOX_PORT=22
SALTBOX_USER=
# Auth: set a password, OR an SSH key path (+ optional passphrase).
SALTBOX_PASSWORD=
SALTBOX_KEY=~/.ssh/id_rsa
SALTBOX_PASSPHRASE=

# Listen address (optional; default :8000).
# SB_UI_ADDR=:8000
